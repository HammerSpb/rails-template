# Copy to .kamal/secrets.production and fill in real values. Gitignored.

POSTGRES_PASSWORD=change-me-prod

# Token required on the `health-check-token` header to reach /readyz from a
# non-local client. Generate with: ruby -rsecurerandom -e 'puts SecureRandom.hex(32)'
HEALTH_CHECK_TOKEN=change-me-prod

# Local registry doesn't authenticate, but Kamal requires a non-empty value.
KAMAL_REGISTRY_PASSWORD=unused
