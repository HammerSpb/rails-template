# Secrets defined here are referenced from config/deploy*.yml as
# `secret: [VAR_NAME]`. Values come from your shell environment or
# from a gitignored .env file (see .env.example).
#
# This file IS checked into git — keep raw credentials out of it.

# Source per-environment vars if present. KAMAL_DESTINATION is set by
# `kamal -d <destination>`; defaults to "production" when omitted.
KAMAL_DESTINATION=${KAMAL_DESTINATION:-production}
if [ -f .env.${KAMAL_DESTINATION} ]; then
  set -a
  . .env.${KAMAL_DESTINATION}
  set +a
fi

RAILS_MASTER_KEY=$(cat config/master.key)
POSTGRES_PASSWORD=$POSTGRES_PASSWORD
KAMAL_REGISTRY_PASSWORD=${KAMAL_REGISTRY_PASSWORD:-}
