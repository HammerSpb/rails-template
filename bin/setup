#!/usr/bin/env ruby
require "fileutils"

APP_ROOT = File.expand_path("..", __dir__)

def system!(*args)
  system(*args, exception: true)
end

FileUtils.chdir APP_ROOT do
  puts "== Installing dependencies =="
  system("bundle check") || system!("bundle install")

  puts "\n== Preparing database =="
  system! "bin/rails db:prepare"
  system! "bin/rails db:reset" if ARGV.include?("--reset")

  puts "\n== Removing old logs and tempfiles =="
  system! "bin/rails log:clear tmp:clear"

  puts "\n== Bootstrapping deploy artifacts =="

  unless File.exist?(".env.production")
    if File.exist?(".env.production.example")
      FileUtils.cp ".env.production.example", ".env.production"
      puts "  created .env.production (from example) - edit it before deploying"
    end
  end

  unless File.exist?(".env.staging")
    if File.exist?(".env.staging.example")
      FileUtils.cp ".env.staging.example", ".env.staging"
      puts "  created .env.staging (from example) - edit it before deploying"
    end
  end

  if system("docker info > /dev/null 2>&1")
    registry_running = system("docker ps --format '{{.Names}}' | grep -q '^rails-template-registry$'")
    unless registry_running
      puts "  starting local Docker registry on localhost:5555"
      system! "docker compose -f docker-compose.registry.yml up -d"
    end
  else
    puts "  Docker not running - skipping registry bootstrap"
  end

  unless ARGV.include?("--skip-server")
    puts "\n== Starting development server =="
    STDOUT.flush
    exec "bin/dev"
  end
end
