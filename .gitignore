# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files, but keep the committed examples.
/.env*
!/.env*.example

# Real per-destination Kamal secrets (gitignored; templates are *.example).
/.kamal/secrets.production
/.kamal/secrets.staging

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore key files for decrypting credentials and more.
/config/*.key

# Local TLS certs (regenerate via bin/generate-local-certs).
/.kamal/certs/

# Database backups.
/backups/

# Kamal runtime state (assets cache, proxy config, accessory data dirs).
# Written by Kamal into the kamal-host container's $HOME (bind-mounted
# here for path-alignment); not source.
/.kamal/apps/
/.kamal/proxy/
/.kamal/*-audit.log
/myapp-staging-db/
/myapp-db/

# Stray dotfiles the kamal-host container creates inside its $HOME.
/.cache/
/.docker/
/.ssh/



